generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleType {
  CAR
  VAN
  TRUCK
  BUS
}

model Vehicle {
  id           String      @id @default(uuid())
  name         String
  licensePlate String      @unique
  type         VehicleType
  createdAt    DateTime    @default(now())
  trips        Trip[]

  @@index([createdAt])
}

model Trip {
  id              String   @id @default(uuid())
  vehicleId       String
  startedAt       DateTime
  endedAt         DateTime
  durationMinutes Int
  distanceKm      Decimal  @db.Decimal(10, 2)
  fuelConsumed    Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([startedAt])
  @@index([vehicleId, startedAt])
}
